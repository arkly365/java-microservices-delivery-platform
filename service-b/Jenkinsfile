pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: '', description: '指定要重新 deploy / rollback 的版本，例如 build-20。留空時走本次 BUILD_NUMBER')
    }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 45, unit: 'MINUTES')
    }

    environment {
        SERVICE_NAME = 'service-b'
        REGISTRY_HOST = 'localhost'
        REGISTRY_PORT = '5000'
        DEV_IMAGE_REPO = "${REGISTRY_HOST}:${REGISTRY_PORT}/${SERVICE_NAME}:dev"
        PROD_IMAGE_REPO = "${REGISTRY_HOST}:${REGISTRY_PORT}/${SERVICE_NAME}:prod"
    }

    stages {
        stage('Init') {
            steps {
                echo 'Pipeline started'
                echo "Branch = ${env.BRANCH_NAME}"
                echo "Input IMAGE_TAG = ${params.IMAGE_TAG}"
            }
        }

        stage('Check Tools') {
            steps {
                sh 'git --version'
                sh 'mvn -version'
                sh 'docker --version'
                sh 'docker compose version'
            }
        }

        stage('Maven Test') {
            steps {
                dir('service-b') {
                    sh 'mvn clean test'
                }
            }
        }

        stage('SonarQube Scan') {
            steps {
                dir('service-b') {
                    retry(2) {
                        withSonarQubeEnv('sonarqube-local') {
                            sh '''
                                mvn -B sonar:sonar \
                                  -Dsonar.projectKey=service-b \
                                  -Dsonar.projectName=service-b
                            '''
                        }
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 10, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Maven Package') {
            steps {
                dir('service-b') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            when {
                expression { return !params.IMAGE_TAG?.trim() }
            }
            steps {
                dir('service-b') {
                    script {
                        if (env.BRANCH_NAME == 'develop') {
                            sh 'docker build -t ${DEV_IMAGE_REPO}-build-${BUILD_NUMBER} .'
                        } else if (env.BRANCH_NAME == 'main') {
                            sh 'docker build -t ${PROD_IMAGE_REPO}-build-${BUILD_NUMBER} .'
                        } else {
                            echo "Skip Docker Build for unsupported branch: ${env.BRANCH_NAME}"
                        }
                    }
                }
            }
        }

        stage('Trivy Report') {
            when {
                expression { return !params.IMAGE_TAG?.trim() }
            }
            steps {
                dir('service-b') {
                    script {
                        if (env.BRANCH_NAME == 'develop') {
                            sh '''
                                docker run --rm \
                                  -v /var/run/docker.sock:/var/run/docker.sock \
                                  -v trivy_cache:/root/.cache/ \
                                  aquasec/trivy:0.62.0 image \
                                  --scanners vuln \
                                  --severity HIGH,CRITICAL \
                                  --ignore-unfixed \
                                  --no-progress \
                                  --format table \
                                  --exit-code 0 \
                                  ${DEV_IMAGE_REPO}-build-${BUILD_NUMBER} \
                                  > trivy-image-report.txt
                            '''
                        } else if (env.BRANCH_NAME == 'main') {
                            sh '''
                                docker run --rm \
                                  -v /var/run/docker.sock:/var/run/docker.sock \
                                  -v trivy_cache:/root/.cache/ \
                                  aquasec/trivy:0.62.0 image \
                                  --scanners vuln \
                                  --severity HIGH,CRITICAL \
                                  --ignore-unfixed \
                                  --no-progress \
                                  --format table \
                                  --exit-code 0 \
                                  ${PROD_IMAGE_REPO}-build-${BUILD_NUMBER} \
                                  > trivy-image-report.txt
                            '''
                        } else {
                            echo "Skip Trivy Report for unsupported branch: ${env.BRANCH_NAME}"
                        }
                    }
                }
            }
        }

        stage('Push Registry') {
            when {
                expression { return !params.IMAGE_TAG?.trim() }
            }
            steps {
                dir('service-b') {
                    script {
                        if (env.BRANCH_NAME == 'develop') {
                            sh '''
                                docker push ${DEV_IMAGE_REPO}-build-${BUILD_NUMBER}
                                docker tag ${DEV_IMAGE_REPO}-build-${BUILD_NUMBER} ${DEV_IMAGE_REPO}-latest
                                docker push ${DEV_IMAGE_REPO}-latest
                            '''
                        } else if (env.BRANCH_NAME == 'main') {
                            sh '''
                                docker push ${PROD_IMAGE_REPO}-build-${BUILD_NUMBER}
                                docker tag ${PROD_IMAGE_REPO}-build-${BUILD_NUMBER} ${PROD_IMAGE_REPO}-latest
                                docker push ${PROD_IMAGE_REPO}-latest
                            '''
                        } else {
                            echo "Skip Push Registry for unsupported branch: ${env.BRANCH_NAME}"
                        }
                    }
                }
            }
        }

		stage('Deploy Dev') {
			when {
				branch 'develop'
			}
			steps {
				dir('service-b') {
					script {
						def deployTag = params.IMAGE_TAG?.trim() ? params.IMAGE_TAG.trim() : "build-${BUILD_NUMBER}"
						sh """
							docker rm -f service-b-dev || true
							APP_BRANCH=develop IMAGE_TAG=${deployTag} docker compose -f deploy/docker-compose.dev.yml up -d
						"""
					}
				}
			}
		}

        stage('Verify Dev') {
            when {
                branch 'develop'
            }
            steps {
                sh 'sleep 10'
                sh 'curl -f http://host.docker.internal:18082/actuator/health'
            }
        }

		stage('Deploy Prod') {
			when {
				branch 'main'
			}
			steps {
				dir('service-b') {
					script {
						def deployTag = params.IMAGE_TAG?.trim() ? params.IMAGE_TAG.trim() : "build-${BUILD_NUMBER}"
						sh """
							docker rm -f service-b-prod || true
							APP_BRANCH=main IMAGE_TAG=${deployTag} docker compose -f deploy/docker-compose.prod.yml up -d
						"""
					}
				}
			}
		}

        stage('Verify Prod') {
            when {
                branch 'main'
            }
            steps {
                sh 'sleep 10'
                sh 'curl -f http://host.docker.internal:28082/actuator/health'
            }
        }

        stage('OWASP ZAP Baseline Scan') {
            steps {
                dir('service-b') {
                    script {
                        if (env.BRANCH_NAME == 'develop') {
                            sh '''
                                docker run --rm \
                                  --network host \
                                  -v "$PWD:/zap/wrk:rw" \
                                  ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                                  -t http://host.docker.internal:18082/actuator/health \
                                  -J zap-report-dev.json \
                                  -r zap-report-dev.html \
                                  -I
                            '''
                            sh 'test -f zap-report-dev.html'
                            sh 'test -f zap-report-dev.json'
                        } else if (env.BRANCH_NAME == 'main') {
                            sh '''
                                docker run --rm \
                                  --network host \
                                  -v "$PWD:/zap/wrk:rw" \
                                  ghcr.io/zaproxy/zaproxy:stable zap-baseline.py \
                                  -t http://host.docker.internal:28082/actuator/health \
                                  -J zap-report-prod.json \
                                  -r zap-report-prod.html \
                                  -I
                            '''
                            sh 'test -f zap-report-prod.html'
                            sh 'test -f zap-report-prod.json'
                        } else {
                            echo "Skip ZAP for unsupported branch: ${env.BRANCH_NAME}"
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'service-b/trivy-image-report.txt', fingerprint: true, allowEmptyArchive: true
            archiveArtifacts artifacts: 'service-b/zap-report-*.html,service-b/zap-report-*.json', fingerprint: true, allowEmptyArchive: true
        }
    }
}