pipeline {
    agent any

    environment {
        SERVICE_NAME = 'service-a'
        REGISTRY = 'localhost:5000'
        IMAGE_REPO = "${REGISTRY}/service-a"

        // 這裡是 host port，可依你實際環境調整
        DEV_PORT  = '18081'
        PROD_PORT = '28081'

        DEV_CONTAINER  = 'service-a-dev'
        PROD_CONTAINER = 'service-a-prod'
    }

    stages {
        stage('Init') {
            steps {
                echo "Start service-a pipeline"
                echo "Branch = ${env.BRANCH_NAME}"
            }
        }

        stage('Check Tools') {
            steps {
                sh 'git --version'
                sh 'mvn -version'
                sh 'docker --version'
            }
        }

        stage('Build Jar') {
            steps {
                dir('service-a') {
                    sh 'mvn clean package -DskipTests'
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('service-a') {
                    sh 'docker build -t service-a:ci-${BUILD_NUMBER} .'
                }
            }
        }

        stage('Push Registry') {
            steps {
                script {
                    if (env.BRANCH_NAME == 'develop') {
                        sh '''
                            docker tag service-a:ci-${BUILD_NUMBER} ${IMAGE_REPO}:dev-latest
                            docker push ${IMAGE_REPO}:dev-latest
                        '''
                    } else if (env.BRANCH_NAME == 'main') {
                        sh '''
                            docker tag service-a:ci-${BUILD_NUMBER} ${IMAGE_REPO}:prod-latest
                            docker push ${IMAGE_REPO}:prod-latest
                        '''
                    } else {
                        echo "Skip push: unsupported branch ${env.BRANCH_NAME}"
                    }
                }
            }
        }

        stage('Deploy Dev') {
            when {
                branch 'develop'
            }
            steps {
                sh '''
                    docker rm -f ${DEV_CONTAINER} || true

                    docker run -d \
                      --name ${DEV_CONTAINER} \
                      -p ${DEV_PORT}:8080 \
                      ${IMAGE_REPO}:dev-latest
                '''
            }
        }

        stage('Verify Dev') {
            when {
                branch 'develop'
            }
            steps {
                sh '''
                    sleep 10
                    curl -f http://host.docker.internal:${DEV_PORT}/hello
                    curl -f http://host.docker.internal:${DEV_PORT}/actuator/health
                '''
            }
        }

        stage('Deploy Prod') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    docker rm -f ${PROD_CONTAINER} || true

                    docker run -d \
                      --name ${PROD_CONTAINER} \
                      -p ${PROD_PORT}:8080 \
                      ${IMAGE_REPO}:prod-latest
                '''
            }
        }

        stage('Verify Prod') {
            when {
                branch 'main'
            }
            steps {
                sh '''
                    sleep 10
                    curl -f http://host.docker.internal:${PROD_PORT}/hello
                    curl -f http://host.docker.internal:${PROD_PORT}/actuator/health
                '''
            }
        }
    }
}